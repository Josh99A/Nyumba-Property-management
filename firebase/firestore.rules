rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPlatformAdmin() {
      return signedIn()
        && (request.auth.token.platformAdmin == true
          || request.auth.token.superAdmin == true);
    }

    function ownsLandlordDocument(data) {
      return signedIn()
        && data.landlordId is string
        && data.landlordId == request.auth.uid;
    }

    function ownsReport(data) {
      return signedIn()
        && data.ownerType == 'landlord'
        && data.ownerId == request.auth.uid;
    }

    function hasActiveLandlordAccount(landlordId) {
      let account = get(/databases/$(database)/documents/landlordAccounts/$(landlordId)).data;
      return account.approvalStatus == 'approved';
    }

    function hasActiveSubscription(landlordId) {
      let sub = get(/databases/$(database)/documents/subscriptions/$(landlordId)).data;
      return sub.status == 'active';
    }

    // Documents are readable only while published and unexpired. `get`
    // evaluates real data, so the timestamp type is checked explicitly. For
    // `list`, the engine cannot statically prove `is timestamp`; the range
    // comparison against request.time is sufficient there because a Firestore
    // range filter over a timestamp bound only ever matches timestamp values.
    function isReadablePublicListingDoc(data) {
      return data.status == 'published'
        && data.expiresAt is timestamp
        && data.expiresAt > request.time;
    }

    function isReadablePublicListingQuery(data) {
      return data.status == 'published'
        && data.expiresAt > request.time;
    }

    // User, approval, and billing documents are server-owned. Profile changes
    // also use a callable command so validation/audit is consistent offline.
    match /users/{uid} {
      allow read: if isSelf(uid) || isPlatformAdmin();
      allow write: if false;
    }

    match /landlordAccounts/{landlordId} {
      allow read: if isSelf(landlordId) || isPlatformAdmin();
      allow write: if false;
    }

    match /subscriptions/{landlordId} {
      allow read: if isSelf(landlordId) || isPlatformAdmin();
      allow write: if false;
    }

    match /planCatalog/{tier} {
      allow get: if isPlatformAdmin() || resource.data.isPublic == true;
      allow list: if isPlatformAdmin()
        || (resource.data.isPublic == true
          && request.query.limit != null
          && request.query.limit <= 20);
      allow write: if false;
    }

    // Canonical landlord-private documents. Landlord list queries must include
    // landlordId == request.auth.uid; Rules do not act as a result filter.
    match /properties/{propertyId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /units/{unitId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /tenantRecords/{tenantRecordId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /leases/{leaseId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /invoices/{invoiceId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /receipts/{receiptId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /maintenanceRequests/{requestId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /notices/{noticeId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /documents/{documentId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /privateListings/{listingId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /applications/{applicationId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /contactRequests/{contactRequestId} {
      allow read: if isPlatformAdmin() || ownsLandlordDocument(resource.data);
      allow write: if false;
    }

    match /reportSnapshots/{reportId} {
      allow read: if isPlatformAdmin() || ownsReport(resource.data);
      allow write: if false;
    }

    // Tenant/client read models contain an explicit field whitelist and are
    // writable only by trusted backend code (Admin SDK bypasses these Rules).
    match /tenantPortals/{tenantUid} {
      allow read: if isSelf(tenantUid) || isPlatformAdmin();
      allow write: if false;
    }

    match /tenantPortals/{tenantUid}/{portalDocument=**} {
      allow read: if isSelf(tenantUid) || isPlatformAdmin();
      allow write: if false;
    }

    match /clientPortals/{clientUid} {
      allow read: if isSelf(clientUid) || isPlatformAdmin();
      allow write: if false;
    }

    match /clientPortals/{clientUid}/{portalDocument=**} {
      allow read: if isSelf(clientUid) || isPlatformAdmin();
      allow write: if false;
    }

    // One uniform, server-owned inbox shape for every authenticated role.
    // Read-state changes cross the callable command boundary so clients never
    // gain write access to a path that also controls recipients and content.
    match /notificationInboxes/{uid} {
      allow read: if isSelf(uid) || isPlatformAdmin();
      allow write: if false;
    }

    match /notificationInboxes/{uid}/{inboxDocument=**} {
      allow read: if isSelf(uid) || isPlatformAdmin();
      allow write: if false;
    }

    // Landlord read models. Unlike the tenant/client portals these withhold
    // nothing the landlord could not already read from the canonical
    // collections; they exist because a client Tenancy is a join across leases,
    // tenantRecords, units, and properties that only the server can perform.
    // Still server-owned and read-only: they are written by the same command
    // transaction as the canonical documents they mirror.
    match /landlordPortals/{landlordId} {
      allow read: if isPlatformAdmin()
        || (isSelf(landlordId)
          && hasActiveLandlordAccount(landlordId)
          && hasActiveSubscription(landlordId));
      allow write: if false;
    }

    match /landlordPortals/{landlordId}/{portalDocument=**} {
      allow read: if isPlatformAdmin()
        || (isSelf(landlordId)
          && hasActiveLandlordAccount(landlordId)
          && hasActiveSubscription(landlordId));
      allow write: if false;
    }

    // Public browsing is deliberately isolated from private property/unit data.
    // Queries must constrain status == published and expiresAt > request.time.
    match /publicListings/{listingId} {
      allow get: if isReadablePublicListingDoc(resource.data);
      allow list: if isReadablePublicListingQuery(resource.data)
        && request.query.limit != null
        && request.query.limit <= 50;
      allow write: if false;
    }

    match /commandReceipts/{commandId} {
      allow read: if isPlatformAdmin()
        || (signedIn() && resource.data.actorUid == request.auth.uid);
      allow write: if false;
    }

    match /auditLogs/{eventId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // Backend jobs and provider payloads are not client-readable, including to
    // platform administrators. Surface operational summaries separately.
    match /backendJobs/{jobId} {
      allow read, write: if false;
    }

    match /providerEvents/{eventId} {
      allow read, write: if false;
    }

    // Fail closed for every collection not explicitly modeled above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
